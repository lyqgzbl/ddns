[Unit]
Description=Cloudflare DDNS service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/ddns-cf
ExecStart=/usr/bin/env uv run ddns-cf --config /etc/ddns-cf/config.toml
Restart=always
RestartSec=10
User=ddns
Group=ddns
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/ddns-cf

[Install]
WantedBy=multi-user.target
